<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/app_name"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_form"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nama -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_nama" />

            <EditText
                android:id="@+id/edtNama"
                style="@style/InputForm"
                android:hint="@string/hint_nama"
                android:inputType="textPersonName" />

            <!-- Email -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_email" />

            <EditText
                android:id="@+id/edtEmail"
                style="@style/InputForm"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress" />

            <!-- HP -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_hp" />

            <EditText
                android:id="@+id/edtHp"
                style="@style/InputForm"
                android:hint="@string/hint_hp"
                android:inputType="phone" />

            <!-- Spinner Film -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_film" />

            <Spinner
                android:id="@+id/spnFilm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#FFFFFF"
                android:padding="8dp" />

            <!-- RadioButton Studio -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_studio" />

            <RadioGroup
                android:id="@+id/rgStudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbRegular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/studio_regular" />

                <RadioButton
                    android:id="@+id/rbVip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/studio_vip" />

                <RadioButton
                    android:id="@+id/rbImax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/studio_imax" />
            </RadioGroup>

            <!-- CheckBox Snack -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_snack" />

            <CheckBox
                android:id="@+id/cbPopcorn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/snack_popcorn" />

            <CheckBox
                android:id="@+id/cbMinuman"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/snack_minuman" />

            <CheckBox
                android:id="@+id/cbNachos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/snack_nachos" />

            <!-- Tanggal & Jam (BONUS) -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_tanggal" />

            <Button
                android:id="@+id/btnTanggal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/text_grey"
                android:text="@string/hint_pilih_tanggal" />

            <TextView
                style="@style/LabelForm"
                android:text="@string/label_jam" />

            <Button
                android:id="@+id/btnJam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/text_grey"
                android:text="@string/hint_pilih_jam" />

            <!-- Jumlah -->
            <TextView
                style="@style/LabelForm"
                android:text="@string/label_jumlah" />

            <EditText
                android:id="@+id/edtJumlah"
                style="@style/InputForm"
                android:hint="@string/hint_jumlah"
                android:inputType="number" />

            <!-- Tombol -->
            <Button
                android:id="@+id/btnPesan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/primary"
                android:text="@string/btn_pesan"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/error_red"
                android:text="@string/btn_reset"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
